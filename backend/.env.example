# The port the signaling server will run on
PORT=9000

# Your Metered.ca TURN API Key (from https://metered.ca/stun-turn)
# Example: 1a2b3c4d5e6f7g8h...
METERED_TURN_API_KEY=your_metered_api_key_here

# (Optional) If you want to use Twilio instead, add these:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
